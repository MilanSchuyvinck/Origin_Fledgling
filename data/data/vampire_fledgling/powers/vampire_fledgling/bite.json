{
  "type": "origins:multiple",
  "name": "Vampiric Bite",
  "description": "Bite a nearby target to drain their life force. Hold Primary Active to feed. Toggle bad effects with CTRL + Primary Active.",

  "toggle_bad_effects": {
    "type": "origins:toggle",
    "active_by_default": true,
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false,
      "condition": {
        "type": "origins:key",
        "key": "key.sprint"
      }
    },
    "name": "Toggle Poison & Nausea",
    "description": "CTRL + Primary Active toggles poison and nausea on your bite target."
  },

  "bite_active": {
    "type": "origins:action_over_time",
    "interval": 20,
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:key",
          "key": "key.origins.primary_active"
        },
        {
          "type": "origins:not",
          "condition": {
            "type": "origins:key",
            "key": "key.sprint"
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:area_of_effect",
      "radius": 4.5,
      "shape": "sphere",
      "bientity_condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:not",
              "condition": {
                "type": "origins:entity_type_tag",
                "tag": "minecraft:undead"
              }
            }
          },
          {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:or",
              "conditions": [
                {
                  "type": "origins:entity_type",
                  "entity_type": "minecraft:player"
                },
				{
  				"type": "origins:entity_type_tag",
 				 "tag": "minecraft:mob"
				},
                {
                  "type": "origins:entity_type_tag",
                  "tag": "minecraft:raiders"
                },
                {
                  "type": "origins:scoreboard",
                  "objective": "dummy",
                  "comparison": ">=",
                  "compare_to": 0
                }
              ]
            }
          }
        ]
      },
      "bientity_action": {
        "type": "origins:both_actions",
        "actor_action": {
          "type": "origins:and",
          "actions": [
            {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:saturation",
                "duration": 40,
                "amplifier": 1
              }
            },
            {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:regeneration",
                "duration": 40,
                "amplifier": 0
              }
            }
          ]
        },
        "target_action": {
          "type": "origins:and",
          "actions": [
            {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:slowness",
                "duration": 40,
                "amplifier": 1
              }
            },
            {
              "type": "origins:if_else",
              "condition": {
                "type": "origins:power_active",
                "power": "vampire_fledgling:bite/toggle_bad_effects"
              },
              "if_action": {
                "type": "origins:and",
                "actions": [
                  {
                    "type": "origins:apply_effect",
                    "effect": {
                      "effect": "minecraft:poison",
                      "duration": 40,
                      "amplifier": 1
                    }
                  },
                  {
                    "type": "origins:apply_effect",
                    "effect": {
                      "effect": "minecraft:nausea",
                      "duration": 40,
                      "amplifier": 0
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    }
  },

  "bite_leash_cleaner": {
    "type": "origins:action_over_time",
    "interval": 2,
    "condition": {
      "type": "origins:not",
      "condition": {
        "type": "origins:key",
        "key": "key.origins.primary_active"
      }
    },
    "entity_action": {
      "type": "origins:area_of_effect",
      "radius": 32,
      "shape": "sphere",
      "bientity_condition": {
        "type": "origins:target_condition",
        "condition": {
          "type": "origins:effect_active",
          "effect": "minecraft:slowness"
        }
      },
      "bientity_action": {
        "type": "origins:target_action",
        "action": {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:slowness"
        }
      }
    }
  },

  "bite_range_check": {
    "type": "origins:action_over_time",
    "interval": 2,
    "condition": {
      "type": "origins:key",
      "key": "key.origins.primary_active"
    },
    "entity_action": {
      "type": "origins:area_of_effect",
      "radius": 32,
      "shape": "sphere",
      "bientity_condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:effect_active",
              "effect": "minecraft:slowness"
            }
          },
          {
            "type": "origins:distance",
            "comparison": ">=",
            "compare_to": 2.0
          }
        ]
      },
      "bientity_action": {
        "type": "origins:target_action",
        "action": {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:slowness"
        }
      }
    }
  },

  "bite_particles": {
    "type": "origins:action_over_time",
    "interval": 4,
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:key",
          "key": "key.origins.primary_active"
        },
        {
          "type": "origins:not",
          "condition": {
            "type": "origins:key",
            "key": "key.sprint"
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:execute_command",
      "command": "particle minecraft:entity_effect ~ ~1 ~ 0.3 0.3 0.3 1 10 force"
    }
  }
}