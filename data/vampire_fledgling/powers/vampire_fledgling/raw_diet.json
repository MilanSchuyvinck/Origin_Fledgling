{
  "type": "origins:multiple",

  "vampire_food_bonus": {
    "type": "origins:modify_food",
    "item_condition": {
      "type": "origins:ingredient",
      "ingredient": {
        "tag": "yourpack:vampire_food"
      }
    },
    "food_modifier": {
      "type": "origins:food_value",
      "food": 4,
      "saturation": 1.0
    }
  },

  "rotten_flesh_bonus": {
    "type": "origins:modify_food",
    "item_condition": {
      "type": "origins:ingredient",
      "ingredient": {
        "item": "minecraft:rotten_flesh"
      }
    },
    "food_modifier": {
      "type": "origins:food_value",
      "food": 8,
      "saturation": 2.0
    }
  },

  "reject_food": {
    "type": "origins:action_on_item_use",
    "item_condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:food"
        },
        {
          "type": "origins:not",
          "condition": {
            "type": "origins:ingredient",
            "ingredient": {
              "tag": "yourpack:vampire_food"
            }
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:hunger",
            "duration": 200,
            "amplifier": 1
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:nausea",
            "duration": 120,
            "amplifier": 0
          }
        }
      ]
    }
  }
}