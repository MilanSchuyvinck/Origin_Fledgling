{
  "type": "origins:multiple",
  "hidden": true,
  "scale": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:execute_command",
      "command": "function vampire_fledgling:vampire_fledgling/size"
    },
    "interval": 20
  },
  "reset": {
    "type": "origins:action_on_callback",
    "entity_action_lost": {
      "type": "origins:execute_command",
      "command": "scale reset"
    }
  },
  "name": "Fledgling Frame",
  "description": "Your new body is tiny. Requires Pehkui for scaling."
}
